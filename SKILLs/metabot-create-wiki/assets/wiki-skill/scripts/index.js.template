#!/usr/bin/env node
'use strict';

const fs = require('node:fs');
const path = require('node:path');
const { spawnSync } = require('node:child_process');
const { parseArgs } = require('node:util');

const REGISTRY_ACTIONS = new Set([
  'registry_create',
  'registry_list',
  'registry_set_default',
  'registry_resolve',
  'registry_remove',
]);

const ACTIONS_THAT_NEED_SYNC = new Set([
  'init',
  'ingest',
  'index',
  'absorb',
  'query',
  'wiki_build',
  'bundle_zip',
  'publish_zip',
  'publish_snapshot',
  'publish_all',
]);

function emitJson(payload, code) {
  process.stdout.write(`${JSON.stringify(payload)}\n`);
  process.exit(code);
}

function fail(code, detail) {
  emitJson({
    success: false,
    action: '',
    kbId: '',
    message: 'wiki skill wrapper failed',
    error: {
      code,
      detail,
      retryable: false,
    },
  }, 1);
}

function readJson(filePath, fallback) {
  if (!fs.existsSync(filePath)) return fallback;
  try {
    return JSON.parse(fs.readFileSync(filePath, 'utf8'));
  } catch {
    return fallback;
  }
}

function ensureDir(dirPath) {
  fs.mkdirSync(dirPath, { recursive: true });
}

function normalizeString(value) {
  return String(value == null ? '' : value).trim();
}

function normalizeArray(value) {
  if (Array.isArray(value)) {
    return value.map((item) => normalizeString(item)).filter(Boolean);
  }
  if (typeof value === 'string') {
    return value
      .split(',')
      .map((item) => normalizeString(item))
      .filter(Boolean);
  }
  return [];
}

function isWithin(parent, child) {
  const rel = path.relative(parent, child);
  return Boolean(rel) && !rel.startsWith('..') && !path.isAbsolute(rel);
}

function resolveSkillsRoot() {
  const envRoot = normalizeString(process.env.SKILLS_ROOT) || normalizeString(process.env.IDBOTS_SKILLS_ROOT);
  if (envRoot) return path.resolve(envRoot);
  return path.resolve(__dirname, '..', '..');
}

function resolveConfigPath() {
  return path.resolve(__dirname, '..', 'wiki.config.json');
}

function loadConfig() {
  const configPath = resolveConfigPath();
  if (!fs.existsSync(configPath)) {
    fail('missing_config', `Missing wiki.config.json: ${configPath}`);
  }

  const config = readJson(configPath, null);
  if (!config || typeof config !== 'object') {
    fail('invalid_config', `Invalid wiki.config.json: ${configPath}`);
  }

  const rawSourceDir = normalizeString(config.rawSourceDir);
  const workspaceRoot = normalizeString(config.workspaceRoot) || path.resolve(path.dirname(configPath), 'workspace');
  const registryHome = normalizeString(config.registryHome) || path.resolve(path.dirname(configPath), '.wiki-home');
  const kbId = normalizeString(config.kbId) || path.basename(path.dirname(configPath));
  const title = normalizeString(config.title) || kbId;

  if (!rawSourceDir) {
    fail('invalid_config', 'wiki.config.json is missing rawSourceDir.');
  }

  return {
    ...config,
    rawSourceDir: path.resolve(rawSourceDir),
    workspaceRoot: path.resolve(workspaceRoot),
    registryHome: path.resolve(registryHome),
    kbId,
    title,
    aliases: normalizeArray(config.aliases),
    siteTitle: normalizeString(config.siteTitle) || title,
    language: normalizeString(config.language) || 'zh-CN',
  };
}

function resolveRuntimeScript(skillsRoot) {
  const runtimeScript = path.join(skillsRoot, 'metabot-llm-wiki', 'scripts', 'index.js');
  if (!fs.existsSync(runtimeScript)) {
    fail('missing_runtime', `Cannot find metabot-llm-wiki runtime at ${runtimeScript}`);
  }
  return runtimeScript;
}

function parsePayloadArg() {
  const { values } = parseArgs({
    options: {
      payload: { type: 'string' },
      help: { type: 'boolean', short: 'h' },
    },
    allowPositionals: true,
  });

  if (values.help) {
    process.stdout.write(
      'Wiki skill wrapper\n' +
        'Usage: node scripts/index.js --payload \'<json>\'\n'
    );
    process.exit(0);
  }

  const raw = normalizeString(values.payload);
  if (raw) {
    try {
      return JSON.parse(raw);
    } catch (error) {
      fail('invalid_payload', `--payload is not valid JSON: ${error.message}`);
    }
  }

  const stdin = fs.readFileSync(0, 'utf8').trim();
  if (!stdin) {
    fail('invalid_payload', 'Missing payload JSON. Use --payload or stdin.');
  }
  try {
    return JSON.parse(stdin);
  } catch (error) {
    fail('invalid_payload', `stdin payload is not valid JSON: ${error.message}`);
  }
}

function runRuntime(runtimeScript, payload) {
  const result = spawnSync(process.execPath, [runtimeScript, '--payload', JSON.stringify(payload)], {
    encoding: 'utf8',
    maxBuffer: 20 * 1024 * 1024,
  });

  if (result.error) {
    fail('runtime_spawn_failed', result.error.message);
  }

  if (result.status !== 0) {
    if (result.stdout) process.stdout.write(result.stdout);
    if (result.stderr) process.stderr.write(result.stderr);
    process.exit(result.status || 1);
  }

  return result.stdout || '';
}

function parseLastJsonLine(stdoutText) {
  const lines = String(stdoutText || '')
    .split(/\r?\n/)
    .map((line) => line.trim())
    .filter(Boolean);
  for (let i = lines.length - 1; i >= 0; i -= 1) {
    try {
      return JSON.parse(lines[i]);
    } catch {
      // continue
    }
  }
  return null;
}

function runRuntimeJson(runtimeScript, payload) {
  const output = runRuntime(runtimeScript, payload);
  const parsed = parseLastJsonLine(output);
  if (!parsed) {
    fail('runtime_parse_failed', 'Runtime did not return a JSON envelope.');
  }
  if (parsed.success === false) {
    fail(
      normalizeString(parsed.error?.code) || 'runtime_failed',
      normalizeString(parsed.error?.detail) || normalizeString(parsed.message) || 'Runtime action failed'
    );
  }
  return parsed;
}

function toFileUri(filePath) {
  return `file://${String(filePath || '').replace(/\\/g, '/')}`;
}

function isExplicitFalse(value) {
  if (value === false || value === 0) return true;
  if (typeof value === 'string') {
    return value.trim().toLowerCase() === 'false' || value.trim() === '0';
  }
  return false;
}

function syncRawSource(config, workspaceRoot) {
  const source = path.resolve(config.rawSourceDir);
  const workspace = path.resolve(workspaceRoot);
  const dest = path.join(workspace, 'raw');

  if (!fs.existsSync(source)) {
    fail('raw_source_missing', `rawSourceDir does not exist: ${source}`);
  }

  if (source === dest || isWithin(source, dest) || isWithin(dest, source)) {
    fail(
      'invalid_raw_source',
      `rawSourceDir must not overlap the generated workspace. source=${source}, workspace=${workspace}`
    );
  }

  ensureDir(workspace);
  fs.rmSync(dest, { recursive: true, force: true });
  ensureDir(path.dirname(dest));
  fs.cpSync(source, dest, { recursive: true, force: true, dereference: true });
  return dest;
}

function defaultWikiConfig(config) {
  return {
    language: config.language || 'zh-CN',
    chunkSize: Number.isFinite(Number(config.chunkSize)) ? Number(config.chunkSize) : 1200,
    chunkOverlap: Number.isFinite(Number(config.chunkOverlap)) ? Number(config.chunkOverlap) : 180,
    embeddingEnabled: config.embeddingEnabled !== false,
    embeddingProvider: ['local-hashing-v1', 'command-json-v1'].includes(normalizeString(config.embeddingProvider).toLowerCase())
      ? normalizeString(config.embeddingProvider).toLowerCase()
      : 'local-hashing-v1',
    embeddingModel: normalizeString(config.embeddingModel) || 'local-hashing-v1',
    embeddingCommand: normalizeString(config.embeddingCommand),
    searchBackend: ['auto', 'hybrid', 'portable', 'sqlite', 'sqlite-fts', 'scan', 'vector'].includes(normalizeString(config.searchBackend).toLowerCase())
      ? normalizeString(config.searchBackend).toLowerCase()
      : 'hybrid',
    lexicalWeight: Number.isFinite(Number(config.lexicalWeight)) ? Number(config.lexicalWeight) : 0.55,
    vectorWeight: Number.isFinite(Number(config.vectorWeight)) ? Number(config.vectorWeight) : 0.35,
    phraseWeight: Number.isFinite(Number(config.phraseWeight)) ? Number(config.phraseWeight) : 0.10,
  };
}

function ensureRegistry(runtimeScript, config, workspaceRoot, registryHome) {
  const payload = {
    action: 'registry_create',
    payload: {
      registryHome,
      kbId: config.kbId,
      title: config.title,
      rootDir: workspaceRoot,
      aliases: config.aliases || [],
      setDefault: true,
      config: defaultWikiConfig(config),
    },
  };
  runRuntime(runtimeScript, payload);
}

function buildActionPayload(input, config, workspaceRoot, registryHome) {
  const payload = input.payload && typeof input.payload === 'object' ? { ...input.payload } : {};

  if (REGISTRY_ACTIONS.has(input.action)) {
    payload.registryHome = payload.registryHome || registryHome;
    return {
      action: input.action,
      kbId: normalizeString(input.kbId) || config.kbId,
      requestId: normalizeString(input.requestId),
      payload,
    };
  }

  payload.registryHome = payload.registryHome || registryHome;
  payload.rootDir = payload.rootDir || workspaceRoot;
  payload.kbId = payload.kbId || config.kbId;
  payload.siteTitle = payload.siteTitle || config.siteTitle || config.title;

  if (input.action === 'init') {
    payload.config = {
      ...defaultWikiConfig(config),
      ...(payload.config && typeof payload.config === 'object' ? payload.config : {}),
    };
  }

  return {
    action: input.action,
    kbId: payload.kbId,
    requestId: normalizeString(input.requestId),
    payload,
  };
}

function runPipeline(runtimeScript, input, config, workspaceRoot, registryHome) {
  if (REGISTRY_ACTIONS.has(input.action)) {
    return runRuntime(runtimeScript, buildActionPayload(input, config, workspaceRoot, registryHome));
  }

  const baseInput = {
    ...input,
    payload: input.payload && typeof input.payload === 'object' ? { ...input.payload } : {},
  };
  const fastQuery = input.action === 'query'
    && baseInput.payload.autoAbsorb !== true
    && baseInput.payload.refresh !== true;

  if (fastQuery) {
    ensureRegistry(runtimeScript, config, workspaceRoot, registryHome);
  } else {
    syncRawSource(config, workspaceRoot);
    ensureRegistry(runtimeScript, config, workspaceRoot, registryHome);
  }

  switch (input.action) {
    case 'init':
      return runRuntime(runtimeScript, buildActionPayload(baseInput, config, workspaceRoot, registryHome));

    case 'ingest':
      return runRuntime(runtimeScript, buildActionPayload(baseInput, config, workspaceRoot, registryHome));

    case 'index':
      runRuntime(
        runtimeScript,
        buildActionPayload({ ...baseInput, action: 'ingest' }, config, workspaceRoot, registryHome)
      );
      return runRuntime(runtimeScript, buildActionPayload(baseInput, config, workspaceRoot, registryHome));

    case 'absorb':
      return runRuntime(runtimeScript, buildActionPayload(baseInput, config, workspaceRoot, registryHome));

    case 'query':
      if (baseInput.payload.autoAbsorb === true || baseInput.payload.refresh === true) {
        runRuntime(
          runtimeScript,
          buildActionPayload({ ...baseInput, action: 'absorb' }, config, workspaceRoot, registryHome)
        );
      }
      return runRuntime(runtimeScript, buildActionPayload(baseInput, config, workspaceRoot, registryHome));

    case 'wiki_build':
      runRuntime(
        runtimeScript,
        buildActionPayload({ ...baseInput, action: 'absorb' }, config, workspaceRoot, registryHome)
      );
      return runRuntime(runtimeScript, buildActionPayload(baseInput, config, workspaceRoot, registryHome));

    case 'bundle_zip':
      runRuntime(
        runtimeScript,
        buildActionPayload({ ...baseInput, action: 'absorb' }, config, workspaceRoot, registryHome)
      );
      runRuntime(
        runtimeScript,
        buildActionPayload({ ...baseInput, action: 'wiki_build' }, config, workspaceRoot, registryHome)
      );
      return runRuntime(runtimeScript, buildActionPayload(baseInput, config, workspaceRoot, registryHome));

    case 'publish_zip':
      runRuntime(
        runtimeScript,
        buildActionPayload({ ...baseInput, action: 'absorb' }, config, workspaceRoot, registryHome)
      );
      if (!(isExplicitFalse(baseInput.payload.uploadZip) && (normalizeString(baseInput.payload.zipUri) || normalizeString(baseInput.payload.pinUri)))) {
        runRuntime(
          runtimeScript,
          buildActionPayload({ ...baseInput, action: 'wiki_build' }, config, workspaceRoot, registryHome)
        );
        runRuntime(
          runtimeScript,
          buildActionPayload({ ...baseInput, action: 'bundle_zip' }, config, workspaceRoot, registryHome)
        );
      }
      return runRuntime(runtimeScript, buildActionPayload(baseInput, config, workspaceRoot, registryHome));

    case 'publish_snapshot':
      runRuntime(
        runtimeScript,
        buildActionPayload({ ...baseInput, action: 'absorb' }, config, workspaceRoot, registryHome)
      );
      runRuntime(
        runtimeScript,
        buildActionPayload({ ...baseInput, action: 'wiki_build' }, config, workspaceRoot, registryHome)
      );
      const explicitZipUri = normalizeString(baseInput.payload.zipUri) || normalizeString(baseInput.payload.pinUri);
      let bundleZipPath = normalizeString(baseInput.payload.zipPath);
      let bundleZipSha256 = normalizeString(baseInput.payload.zipSha256);
      if (!explicitZipUri && !bundleZipPath) {
        const bundleOutput = runRuntime(
          runtimeScript,
          buildActionPayload({ ...baseInput, action: 'bundle_zip' }, config, workspaceRoot, registryHome)
        );
        const bundleResult = parseLastJsonLine(bundleOutput);
        bundleZipPath = normalizeString(bundleResult?.data?.zipPath);
        bundleZipSha256 = normalizeString(bundleResult?.data?.zipSha256);
      }
      if (!bundleZipPath && !explicitZipUri) {
        fail('bundle_zip_failed', 'bundle_zip did not return data.zipPath for publish_snapshot.');
      }
      const snapshotPayload = {
        ...baseInput.payload,
        zipPath: bundleZipPath || baseInput.payload.zipPath,
        zipUri: explicitZipUri || (bundleZipPath ? toFileUri(bundleZipPath) : baseInput.payload.zipUri),
        zipSha256: bundleZipSha256 || baseInput.payload.zipSha256,
      };
      return runRuntime(
        runtimeScript,
        buildActionPayload({ ...baseInput, payload: snapshotPayload }, config, workspaceRoot, registryHome)
      );

    case 'publish_all':
      if (isExplicitFalse(baseInput.payload.uploadZip) && !normalizeString(baseInput.payload.zipUri) && !normalizeString(baseInput.payload.pinUri)) {
        const startedAt = Date.now();
        const warnings = [];
        const steps = {};
        const absorbResult = runRuntimeJson(
          runtimeScript,
          buildActionPayload({ ...baseInput, action: 'absorb' }, config, workspaceRoot, registryHome)
        );
        steps.absorb = absorbResult.data;
        if (Array.isArray(absorbResult.warnings)) warnings.push(...absorbResult.warnings);

        const skipWikiBuild = baseInput.payload.skipWikiBuild === true;
        const skipBundle = baseInput.payload.skipBundle === true;
        const skipSnapshot = baseInput.payload.skipSnapshot === true;

        if (!skipWikiBuild) {
          const wikiResult = runRuntimeJson(
            runtimeScript,
            buildActionPayload({ ...baseInput, action: 'wiki_build' }, config, workspaceRoot, registryHome)
          );
          steps.wiki_build = wikiResult.data;
          if (Array.isArray(wikiResult.warnings)) warnings.push(...wikiResult.warnings);
        }

        let effectiveZipPath = normalizeString(baseInput.payload.zipPath);
        let effectiveZipSha256 = normalizeString(baseInput.payload.zipSha256);
        if (!skipBundle && !effectiveZipPath) {
          const bundleResult = runRuntimeJson(
            runtimeScript,
            buildActionPayload({ ...baseInput, action: 'bundle_zip' }, config, workspaceRoot, registryHome)
          );
          steps.bundle_zip = bundleResult.data;
          if (Array.isArray(bundleResult.warnings)) warnings.push(...bundleResult.warnings);
          effectiveZipPath = normalizeString(bundleResult.data?.zipPath) || effectiveZipPath;
          effectiveZipSha256 = normalizeString(bundleResult.data?.zipSha256) || effectiveZipSha256;
        }

        steps.publish_zip = {
          skipped: true,
          reason: 'uploadZip=false and no external zipUri provided; keeping ZIP local.',
          zipPath: effectiveZipPath,
          zipSha256: effectiveZipSha256,
          publishMode: {
            uploadZip: false,
            source: 'local_only',
            explicitUploadZip: true,
          },
        };

        if (!skipSnapshot) {
          const snapshotPayload = {
            ...baseInput.payload,
            zipPath: effectiveZipPath,
            zipUri: effectiveZipPath ? toFileUri(effectiveZipPath) : baseInput.payload.zipUri,
            zipSha256: effectiveZipSha256,
          };
          const snapshotResult = runRuntimeJson(
            runtimeScript,
            buildActionPayload({ ...baseInput, action: 'publish_snapshot', payload: snapshotPayload }, config, workspaceRoot, registryHome)
          );
          steps.publish_snapshot = snapshotResult.data;
          if (Array.isArray(snapshotResult.warnings)) warnings.push(...snapshotResult.warnings);
        }

        return `${JSON.stringify({
          success: true,
          action: 'publish_all',
          kbId: baseInput.kbId,
          message: 'Publish all pipeline completed',
          data: {
            steps,
            publishMode: {
              uploadZip: false,
              snapshotOnChain: baseInput.payload.snapshotOnChain === true || baseInput.payload.publishOnChain === true,
              snapshotFlagSource: baseInput.payload.snapshotOnChain !== undefined
                ? 'snapshotOnChain'
                : (baseInput.payload.publishOnChain !== undefined ? 'publishOnChain' : 'default'),
            },
          },
          warnings,
          metrics: {
            elapsedMs: Date.now() - startedAt,
          },
        })}\n`;
      }

      runRuntime(
        runtimeScript,
        buildActionPayload({ ...baseInput, action: 'absorb' }, config, workspaceRoot, registryHome)
      );
      return runRuntime(runtimeScript, buildActionPayload(baseInput, config, workspaceRoot, registryHome));

    default:
      fail('invalid_action', `Unsupported action "${input.action}" for this wiki skill.`);
  }
}

function main() {
  const input = parsePayloadArg();
  if (!input || typeof input !== 'object') {
    fail('invalid_payload', 'Payload must be a JSON object.');
  }

  const config = loadConfig();
  const skillsRoot = resolveSkillsRoot();
  const runtimeScript = resolveRuntimeScript(skillsRoot);
  const workspaceRoot = path.resolve(
    normalizeString(input?.payload?.workspaceRoot)
      || normalizeString(config.workspaceRoot)
      || path.join(path.dirname(resolveConfigPath()), 'workspace')
  );
  const registryHome = path.resolve(
    normalizeString(input?.payload?.registryHome)
      || normalizeString(config.registryHome)
      || path.join(path.dirname(resolveConfigPath()), '.wiki-home')
  );

  const output = runPipeline(runtimeScript, input, config, workspaceRoot, registryHome);
  process.stdout.write(output);
}

main();

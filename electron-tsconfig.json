{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": false,
    "sourceMap": true,
    "baseUrl": ".",
    "outDir": "dist-electron",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "types": ["node"],
    "paths": { "*": ["node_modules/*"] }
  },
  "include": ["src/main"]
}
